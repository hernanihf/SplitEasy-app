{
  "name": "SplitEasy",
  "short_name": "SplitEasy",
  "description": "Split expenses with friends and let AI fill them in from a receipt.",
  "lang": "en",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#0E7C5A",
  "background_color": "#0F1A16",
  "icons": [
    {
      "src": "/icons/pwa-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/pwa-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/pwa-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/home.png",
      "sizes": "750x1624",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "See every group's balance at a glance"
    },
    {
      "src": "/screenshots/group.png",
      "sizes": "750x1624",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Track who paid what and who owes who"
    },
    {
      "src": "/screenshots/add-expense.png",
      "sizes": "750x1624",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Add an expense and split it in seconds"
    }
  ],
  "shortcuts": [
    {
      "name": "New expense",
      "short_name": "New expense",
      "description": "Add an expense to the group you had open last",
      "url": "/shortcut/add-expense",
      "icons": [{ "src": "/icons/pwa-192.png", "sizes": "192x192" }]
    },
    {
      "name": "View balance",
      "short_name": "Balance",
      "description": "See your balance in the group you had open last",
      "url": "/shortcut/balance",
      "icons": [{ "src": "/icons/pwa-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [{ "name": "receipt", "accept": ["image/*"] }]
    }
  }
}
