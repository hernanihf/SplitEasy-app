{
  "expo": {
    "name": "SplitEasy",
    "slug": "SplitEasy-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spliteasyapp",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#208AEF",
    "backgroundColor": "#208AEF",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "SplitEasy",
      "shortName": "SplitEasy",
      "lang": "en",
      "themeColor": "#208AEF",
      "backgroundColor": "#208AEF",
      "display": "standalone",
      "startUrl": "/",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "SplitEasy necesita acceso a tus fotos para escanear tickets.",
          "cameraPermission": "SplitEasy necesita la cámara para escanear tickets."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
